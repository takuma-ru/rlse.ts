{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && tsc -b && vite build --mode client && vite build",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "pnpm exec oxlint --config ../oxlint.config.ts .",
    "lint:fix": "pnpm exec oxlint --config ../oxlint.config.ts --fix .",
    "format": "pnpm exec oxfmt --config ../oxfmt.config.ts .",
    "format:check": "pnpm exec oxfmt --config ../oxfmt.config.ts --check .",
    "check": "pnpm run format:check && pnpm run lint",
    "preview": "pnpm run build && wrangler dev --local"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.0.1",
    "@types/mdx": "^2.0.13",
    "@vanilla-extract/css": "^1.15.3",
    "clsx": "^2.1.1",
    "github-markdown-css": "^5.6.1",
    "hono": "^4.6.3",
    "normalize.css": "^8.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.6.2",
    "@hono/vite-dev-server": "^0.18.2",
    "@shikijs/rehype": "^1.12.1",
    "@types/hast": "^3.0.4",
    "@types/unist": "^3.0.3",
    "@vanilla-extract/vite-plugin": "^4.0.13",
    "globals": "^15.9.0",
    "hast": "^1.0.0",
    "typescript": "^5.5.3",
    "unist": "^0.0.1",
    "unist-util-visit": "^5.0.0",
    "unplugin-fonts": "^1.1.1",
    "vite": "^5.4.0",
    "wrangler": "^4.90.0"
  }
}
