{
  "name": "rlse-workspace",
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "license": "MPL-2.0",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "NODE_OPTIONS=--experimental-strip-types pnpm exec oxlint --config ./oxlint.config.ts .",
    "lint:fix": "NODE_OPTIONS=--experimental-strip-types pnpm exec oxlint --config ./oxlint.config.ts --fix .",
    "fmt": "NODE_OPTIONS=--experimental-strip-types pnpm exec oxfmt --config ./oxfmt.config.ts .",
    "fmt:check": "NODE_OPTIONS=--experimental-strip-types pnpm exec oxfmt --config ./oxfmt.config.ts --check .",
    "check": "pnpm run fmt:check && pnpm run lint",
    "p:core": "pnpm -C packages/core",
    "pg:vanilla-ts": "pnpm -C playgrounds/vanilla-ts",
    "p:docs": "pnpm -C docs"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.0.6"
  },
  "engines": {
    "npm": "please_use_pnpm_instead",
    "pnpm": "9.5.0",
    "yarn": "please_use_pnpm_instead"
  },
  "volta": {
    "node": "22.12.0",
    "pnpm": "9.5.0"
  },
  "packageManager": "pnpm@9.5.0"
}
