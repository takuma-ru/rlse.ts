{
  "name": "vanilla-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "pnpm exec oxlint --config ../../oxlint.config.ts .",
    "lint:fix": "pnpm exec oxlint --config ../../oxlint.config.ts --fix .",
    "format": "pnpm exec oxfmt --config ../../oxfmt.config.ts .",
    "format:check": "pnpm exec oxfmt --config ../../oxfmt.config.ts --check .",
    "check": "pnpm run format:check && pnpm run lint",
    "preview": "vite preview",
    "link:core": "pnpm link ../../packages/core",
    "rlse:test": "pnpm link:core && pnpm exec rlse"
  },
  "devDependencies": {
    "rlse.ts": "workspace:*",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^5.3.5"
  }
}
