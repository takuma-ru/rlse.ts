{
  "name": "@takuma-ru/rlse",
  "version": "0.0.2",
  "private": false,
  "homepage": "https://github.com/takuma-ru/rlse",
  "bugs": {
    "url": "https://github.com/takuma-ru/rlse/issues",
    "email": "takuma-ru@takumaru.dev"
  },
  "license": "MPL-2.0",
  "author": "takuma-ru <takuma-ru@takumaru.dev> (https://github.com/takuma-ru/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/takuma-ru/rlse"
  },
  "bin": {
    "rlse": "./bin/bin.js"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/main.js",
        "types": "./dist/main.d.ts"
      },
      "require": {
        "default": "./dist/main.cjs",
        "types": "./dist/main.d.cts"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "test": "pnpm build && node --test ./test/*.test.mjs",
    "lint": "pnpm exec oxlint --config ../../oxlint.config.ts .",
    "lint:fix": "pnpm exec oxlint --config ../../oxlint.config.ts --fix .",
    "format": "pnpm exec oxfmt --config ../../oxfmt.config.ts .",
    "format:check": "pnpm exec oxfmt --config ../../oxfmt.config.ts --check .",
    "check": "pnpm run format:check && pnpm run lint",
    "start": "node ./dist/main.js",
    "link:core": "pnpm link .",
    "release": "pnpm link:core && rlse"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "semver": "^7.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@takuma-ru/rlse": "workspace:*",
    "@types/node": "^20.14.2",
    "@types/semver": "^7.5.8",
    "tsup": "^8.1.0",
    "typescript": "^5.2.2"
  }
}
